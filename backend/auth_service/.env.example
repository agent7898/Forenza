# ─────────────────────────────────────────────────────────────
#  Auth Microservice — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# PostgreSQL / Supabase connection string
# Supabase pooler URL (port 6543 = transaction mode, recommended for serverless)
DATABASE_URL=postgres://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# JWT signing secret — must be the SAME value used in the main backend (Member 2)
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_long_random_hex_string
