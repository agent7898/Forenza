# Frontend environment variables
# Copy this file to .env.local and set real values.
# NEVER commit .env.local to version control.

# URL of the main backend (Member 2's FastAPI service on :8000).
# When running the Vite dev server, the built-in proxy in vite.config.js
# already forwards /api/* to localhost:8000 — so this variable is only
# needed when you deploy or want to override the proxy target.
VITE_API_URL=http://localhost:8000
